# Copy to .env and fill in. .env is gitignored.

# Required — your OpenAI API key. The sample app calls OpenAI directly via
# ruby_llm; the gem under test instruments the call.
OPENAI_API_KEY=sk-...

# Required — OTLP endpoint to send the emitted spans to. For Last9 this is
# https://otlp.last9.io (or your dedicated cluster URL). For any other
# OTLP-compatible backend (Jaeger, Tempo, Honeycomb, Grafana Cloud, etc.)
# point at their /v1/traces endpoint.
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.last9.io

# Required — OTLP auth headers, formatted as comma-separated key=value
# pairs. For Last9 use the Basic auth value from your cluster integration
# page.
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-creds>

# Optional — service name attribute on the exported resource. Defaults to
# "ruby-llm-otel-demo" when unset.
OTEL_SERVICE_NAME=ruby-llm-otel-demo

# Optional — model id for the demo (defaults to gpt-4o-mini).
DEMO_MODEL=gpt-4o-mini

# Optional — when set to "1", emit prompt + completion text as OTel span
# events. Off by default to keep PII out of traces. Read the gem's README
# for the full PII contract before flipping this in any production-adjacent
# environment.
CAPTURE_MESSAGE_CONTENT=0

# Optional — when set to "1", swap the OTLP exporter for the OTel SDK's
# console exporter and skip the OTLP creds check. Useful for local
# verification without OTLP credentials — spans are printed to stdout
# instead of shipped to Last9.
USE_CONSOLE_EXPORTER=0
