# OpenResty service identity
OTEL_SERVICE_NAME=openresty
OTEL_SERVICE_VERSION=1.0.0
DEPLOYMENT_ENVIRONMENT=production

# Last9 credentials — fill in from your Last9 dashboard
# The OTel Collector config uses these at startup
LAST9_OTLP_ENDPOINT=<your-last9-otlp-endpoint>
LAST9_OTLP_AUTH=<your-last9-otlp-auth-header>
