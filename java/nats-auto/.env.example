# OTel SDK standard env vars — picked up directly by the Java agent.
# Get your endpoint and credentials from https://app.last9.io → Integrations → OTLP.
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.last9.io
# Format: key=value (OTel SDK header format)
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <your-base64-encoded-credentials>
OTEL_TRACES_SAMPLER=always_on
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local

# OTel Collector exporter — needs just the header value (not key=value)
LAST9_OTLP_AUTH_HEADER=Basic <your-base64-encoded-credentials>

# Used by the OTel Collector's resource processor
DEPLOYMENT_ENV=local
