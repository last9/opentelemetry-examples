# Service identity
OTEL_SERVICE_NAME=braintrust-direct-example
DEPLOYMENT_ENV=local

# Last9 OTLP credentials — Integrations → OpenTelemetry in app.last9.io
# LAST9_OTLP_ENDPOINT must be the BASE URL only (no /v1/traces path).
LAST9_OTLP_ENDPOINT=<your-last9-otlp-endpoint>
LAST9_OTLP_AUTH=Basic <your-last9-credentials>

# Braintrust — https://www.braintrust.dev/app/settings/api-keys
BRAINTRUST_API_KEY=<your-braintrust-api-key>
BRAINTRUST_PARENT=project_name:last9-otel-example

# OpenAI — workload calls gpt-4o-mini
OPENAI_API_KEY=<your-openai-api-key>
