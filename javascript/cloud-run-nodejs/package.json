{
  "name": "cloud-run-nodejs-otel",
  "version": "1.0.0",
  "description": "OpenTelemetry example for Google Cloud Run with Node.js",
  "main": "app.js",
  "scripts": {
    "start": "node --require ./instrumentation.js app.js"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
