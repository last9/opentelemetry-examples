# Service identity
OTEL_SERVICE_NAME=braintrust-collector-example
DEPLOYMENT_ENV=local

# App → local collector
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

# Last9 OTLP credentials — used by the collector exporter, not the app.
# LAST9_OTLP_ENDPOINT must be the BASE URL only (no /v1/traces path).
LAST9_OTLP_ENDPOINT=<your-last9-otlp-endpoint>
LAST9_OTLP_AUTH=Basic <your-last9-credentials>

# Braintrust — used by the collector exporter, not the app.
BRAINTRUST_API_KEY=<your-braintrust-api-key>
BRAINTRUST_PROJECT=last9-otel-example

# OpenAI — workload calls gpt-4o-mini
OPENAI_API_KEY=<your-openai-api-key>
