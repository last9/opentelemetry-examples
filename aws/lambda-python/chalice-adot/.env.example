# Required for deploy-all.sh (envsubst into collector-config.yaml.tmpl + config.json.in).
# Use a non-production Last9 workspace or dummy value for layer-only testing.
LAST9_OTLP_AUTH="Basic <your-base64-credentials>"

# IAM execution role for the Lambda function. experiments-engineer cannot create
# IAM roles, so re-use any existing Lambda execution role in your account with
# AWSLambdaBasicExecutionRole attached. Required by all variants.
LAMBDA_EXEC_ROLE_ARN=arn:aws:iam::<your-account-id>:role/<existing-lambda-exec-role>

# Variant D only: ARN of a Lambda layer that contains pip deps (filetype, aiohttp, etc.)
# Publish with: scripts/publish-deps-layer.sh
DEPS_LAYER_ARN=arn:aws:lambda:<region>:<your-account-id>:layer:chalice-adot-deps:1
