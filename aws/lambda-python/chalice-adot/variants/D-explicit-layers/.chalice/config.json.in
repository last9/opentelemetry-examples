{
  "version": "2.0",
  "app_name": "chalice-adot-d",
  "automatic_layer": true,
  "stages": {
    "dev": {
      "api_gateway_stage": "dev",
      "lambda_memory_size": 512,
      "lambda_timeout": 30,
      "tags": {
        "Project": "chalice-adot",
        "chalice-adot-variant": "D"
      },
      "layers": [
        "arn:aws:lambda:ap-south-1:901920570463:layer:aws-otel-python-amd64-ver-1-32-0:2",
        "__DEPS_LAYER_ARN__"
      ],
      "environment_variables": {
        "AWS_LAMBDA_EXEC_WRAPPER": "/opt/otel-instrument",
        "OPENTELEMETRY_COLLECTOR_CONFIG_FILE": "/var/task/chalicelib/collector-config.yaml",
        "OTEL_SERVICE_NAME": "chalice-adot-d",
        "OTEL_TRACES_EXPORTER": "otlp",
        "OTEL_METRICS_EXPORTER": "otlp",
        "OTEL_LOGS_EXPORTER": "otlp",
        "OTEL_EXPORTER_OTLP_PROTOCOL": "http/protobuf",
        "OTEL_RESOURCE_ATTRIBUTES": "deployment.environment=ci,service.namespace=chalice-adot"
      },
      "manage_iam_role": false,
      "iam_role_arn": "__LAMBDA_EXEC_ROLE_ARN__"
    }
  }
}