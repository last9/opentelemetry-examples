# Last9 Credentials (from Settings > Integrations > Send Data)

# For No-Lambda template (cloudformation-no-lambda.yaml):
LAST9_HOST=<your-host>.last9.io
LAST9_USERNAME=<your-username>
LAST9_PASSWORD=<your-password>

# For Lambda template (cloudformation.yaml):
LAST9_OTLP_ENDPOINT=https://<your-host>.last9.io/v1/logs
LAST9_AUTH_TOKEN=<base64-encoded-username:password>

# Optional: filter to a specific ECS cluster
ECS_CLUSTER_ARN=

# Optional: service_name tag (no-lambda only, default: ecs-lifecycle)
SERVICE_NAME=ecs-lifecycle
