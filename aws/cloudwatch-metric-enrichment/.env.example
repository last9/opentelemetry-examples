# AWS Configuration
AWS_REGION=<your-aws-region>

# Cross-account tag enrichment (optional)
# JSON map of AWS account IDs to IAM role ARNs
# Example: {"123456789012":"arn:aws:iam::123456789012:role/Last9MetricEnrichment"}
CROSS_ACCOUNT_ROLES={}

# Tag cache TTL (Go duration format)
TAG_CACHE_TTL=1h

# Log verbosity: info or debug
LOG_LEVEL=info

# Skip enrichment on tag API errors instead of failing the record
CONTINUE_ON_TAG_FAILURE=true
