// Last9 RUM — example secrets template.
//
// Copy this file to `Secrets.xcconfig` (git-ignored) and fill in your values:
//
//     cp Secrets.example.xcconfig Secrets.xcconfig
//
// IMPORTANT — the "//" scheme problem:
// xcconfig treats "//" as the start of a comment, so a value like
// "https://otlp-ext-aps1.last9.io/..." would be silently truncated to
// "https:". To avoid this, store URLs WITHOUT the "https://" scheme. The app
// re-adds "https://" at runtime (see Sources/RUMConfig.swift).
//
// So enter only the host + path, e.g.:
//   otlp-ext-aps1.last9.io/v1/otlp/organizations/your-org
// NOT:
//   https://otlp-ext-aps1.last9.io/v1/otlp/organizations/your-org

// OTLP collector endpoint (host + path, NO scheme). Maps to L9RumConfig.baseUrl.
LAST9_BASE_URL = otlp-ext-aps1.last9.io/v1/otlp/organizations/your-org

// Authentication token from the Last9 dashboard. Maps to L9RumConfig.clientToken.
LAST9_CLIENT_TOKEN = your-client-token

// Origin sent as the X-LAST9-ORIGIN header (host, NO scheme).
// Required for client_monitoring tokens. Maps to L9RumConfig.origin.
LAST9_ORIGIN = app.last9.io

// --- Last9 RUM iOS SDK source (distributed via Last9 CDN) -------------------
// The SDK is pulled by CocoaPods from the CDN podspec (see Podfile):
//   https://cdn.last9.io/rum-sdk/ios/builds/<version>/Last9RUM.podspec
// The version defaults to 0.7.1; override it for `pod install` with:
//   export LAST9_RUM_VERSION=<version>
// (This is a build-time pod source, not a runtime Info.plist value, so it is
//  read by the Podfile rather than from this xcconfig.)
