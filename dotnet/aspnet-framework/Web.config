<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <system.web>
    <compilation debug="true" targetFramework="4.7.2" />
    <httpRuntime targetFramework="4.7.2" />
  </system.web>

  <system.webServer>
    <handlers>
      <!-- Required for Web API attribute routing -->
      <remove name="ExtensionlessUrlHandler-Integrated-4.0" />
      <remove name="OPTIONSVerbHandler" />
      <remove name="TRACEVerbHandler" />
      <add name="ExtensionlessUrlHandler-Integrated-4.0"
           path="*." verb="*"
           type="System.Web.HttpForbiddenHandler" />
    </handlers>
    <modules runAllManagedModulesForAllRequests="true" />
    <directoryBrowse enabled="false" />
  </system.webServer>

  <!--
    OTEL environment variables are set on the IIS app pool via setup-otel.ps1.
    Do NOT put credentials or OTLP endpoints in Web.config — they belong in
    the app pool environment so each service can have its own service.name.

    If you must override per-app (only when sharing an app pool), you can set:
    <appSettings>
      <add key="OTEL_SERVICE_NAME" value="my-service" />
    </appSettings>

    WARNING: Shared app pool override only works for the FIRST app in the pool.
    See README troubleshooting section for details.
  -->
</configuration>
