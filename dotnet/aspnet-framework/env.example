# OTel environment variables for ASP.NET Framework 4.x on IIS
#
# These are set on the IIS App Pool via setup-otel.ps1, NOT as system env vars.
# This file is for reference only — copy values into setup-otel.ps1 parameters.
#
# Usage:
#   .\setup-otel.ps1 `
#       -AppPoolName "YourAppPool" `
#       -ServiceName "your-service" `
#       -OtlpEndpoint "http://gateway-vm:4317"

# Service identity
OTEL_SERVICE_NAME=your-service-name
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,host.name=SERVERNAME

# Exporter — point at gateway collector (recommended) or directly at Last9
OTEL_EXPORTER_OTLP_ENDPOINT=http://gateway-vm:4317
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Uncomment for direct-to-Last9 (no gateway):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.last9.io
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-token>

# Signals
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=none

# Propagation (W3C — compatible with all downstream services)
OTEL_PROPAGATORS=tracecontext,baggage

# Sampling — parentbased_traceidratio respects upstream decisions
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0
