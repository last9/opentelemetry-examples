# OTel environment variables for ASP.NET Core (.NET 6+)
#
# IIS mode:    set via setup-otel.ps1 (applied to the IIS app pool)
# Kestrel mode: run setup-otel.ps1 -Mode kestrel to generate otel.env,
#               then load it before dotnet run (see README).

# Service identity
OTEL_SERVICE_NAME=your-service-name
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=production,host.name=SERVERNAME

# Exporter — point at gateway collector (recommended) or directly at Last9
OTEL_EXPORTER_OTLP_ENDPOINT=http://gateway-vm:4317
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
# Uncomment for direct-to-Last9 (no gateway):
# OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.last9.io
# OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-token>

# Signals
OTEL_TRACES_EXPORTER=otlp
OTEL_METRICS_EXPORTER=otlp
OTEL_LOGS_EXPORTER=none

# Propagation
OTEL_PROPAGATORS=tracecontext,baggage

# Sampling
OTEL_TRACES_SAMPLER=parentbased_traceidratio
OTEL_TRACES_SAMPLER_ARG=1.0

# CLR profiler — auto-set by setup-otel.ps1; shown here for reference
# OTEL_DOTNET_AUTO_HOME=C:\Program Files\OpenTelemetry .NET AutoInstrumentation
# CORECLR_ENABLE_PROFILING=1
# CORECLR_PROFILER={918728DD-259F-4A6A-AC2B-B85E1B658318}
# CORECLR_PROFILER_PATH_64=...\win-x64\OpenTelemetry.AutoInstrumentation.Native.dll
