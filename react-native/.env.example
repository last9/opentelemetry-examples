# Last9 RUM credentials — copy this file to `.env` and fill in real values.
# `.env` is git-ignored; never commit real tokens.
#
# Expo automatically loads `.env` and inlines any EXPO_PUBLIC_* variable into
# `process.env` at build time. src/rum.ts reads these three keys.

# OTLP collector endpoint (contains your org path)
EXPO_PUBLIC_LAST9_BASE_URL=https://otlp-ext-aps1.last9.io/v1/otlp/organizations/<org>

# Authentication token from the Last9 dashboard
EXPO_PUBLIC_LAST9_CLIENT_TOKEN=your-client-token

# Origin sent as the X-LAST9-ORIGIN header (required for client_monitoring tokens)
EXPO_PUBLIC_LAST9_ORIGIN=https://app.last9.io

# --- Last9 RUM React Native SDK source (distributed via Last9 CDN) ---
# The SDK is installed from the CDN npm tarball, pinned in package.json:
#   https://cdn.last9.io/rum-sdk/react-native/builds/<version>/last9-rum-react-native-<version>.tgz
# To change the version, update that dependency in package.json (currently 0.7.1)
# and re-run `npm install`. The Android/iOS native deps also come from the CDN
# and are injected at `expo prebuild` by the config plugin in
# plugins/withLast9Rum.js (Maven repo for Android, podspec for iOS).
