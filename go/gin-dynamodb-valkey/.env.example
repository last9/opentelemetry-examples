# ---- Last9 OTLP ----
export OTEL_EXPORTER_OTLP_ENDPOINT="<your-last9-otlp-endpoint>"
export OTEL_EXPORTER_OTLP_HEADERS="Authorization=<your-last9-auth-value>"
export OTEL_SERVICE_NAME="gin-dynamodb-valkey-example"
export OTEL_TRACES_SAMPLER="always_on"
export OTEL_RESOURCE_ATTRIBUTES="deployment.environment=local"

# ---- DynamoDB ----
# AWS_ENDPOINT_URL: set only for DynamoDB-local. Remove in production so the
# AWS SDK uses the real regional endpoint.
export AWS_ENDPOINT_URL="http://localhost:8000"
export AWS_REGION="<your-aws-region>"
# Use IAM role / instance profile in production. These are dummy values for
# DynamoDB-local only.
export AWS_ACCESS_KEY_ID="local"
export AWS_SECRET_ACCESS_KEY="local"
export DYNAMODB_TABLE="users"

# ---- Valkey ----
# Comma-separated for cluster / sentinel nodes.
export VALKEY_ADDR="localhost:6379"
# Set to true for managed Valkey that requires TLS (ElastiCache/MemoryDB with
# encryption enabled, Upstash, Aiven, Redis Cloud). Omit for plaintext.
export VALKEY_TLS="false"
# Leave blank unless your Valkey has ACL / password auth.
export VALKEY_USERNAME=""
export VALKEY_PASSWORD=""
