// Copy to Secrets.xcconfig and fill in your values. Do not commit Secrets.xcconfig.
// Xcode xcconfig treats // as comments, so keep URL values without the https:// scheme.

LAST9_BASE_URL = otlp-ext-aps1.last9.io/v1/otlp/organizations/<org>
LAST9_CLIENT_TOKEN = <your-client-token>
LAST9_ORIGIN = app.last9.io
