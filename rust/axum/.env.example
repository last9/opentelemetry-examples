# Last9 OTLP endpoint — get from Last9 dashboard → Integrations → OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=https://otlp.last9.io

# Basic Auth header from Last9 dashboard
# Format: Authorization=Basic <base64(username:password)>
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <your-base64-credentials>

# Service identification
OTEL_SERVICE_NAME=rust-axum-service
OTEL_SERVICE_VERSION=1.0.0
DEPLOYMENT_ENVIRONMENT=production

# Log level (optional, defaults to info)
RUST_LOG=info
