# PostgreSQL Configuration
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=holdingdb
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Application Configuration
APP_PORT=8080
PRICING_SERVICE_URL=http://localhost:8081

# OpenTelemetry Configuration
OTEL_SERVICE_NAME=holding-service
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf
OTEL_TRACES_EXPORTER=otlp
OTEL_LOGS_EXPORTER=otlp
OTEL_RESOURCE_ATTRIBUTES=deployment.environment=local,service.version=1.0.0

# Last9 Configuration (for OTel Collector)
LAST9_OTLP_ENDPOINT=https://otlp.last9.io
LAST9_OTLP_AUTH_HEADER=Basic <your-credentials>
