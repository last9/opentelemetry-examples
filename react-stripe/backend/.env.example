# Copy to .env and fill in your values

# Stripe keys — get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret_here

# CORS — allow the React frontend origin
CORS_ALLOWED_ORIGINS=http://localhost:3000

# ── Last9 OpenTelemetry ────────────────────────────────────────────────────────
# Backend uses a standard authorization token (not a client token)
#
# 1. Get your OTLP endpoint from the Last9 dashboard
# 2. Get your auth token from https://app.last9.io/control-plane/ingestion-tokens

OTEL_SERVICE_NAME=stripe-payments-api
OTEL_EXPORTER_OTLP_ENDPOINT=<your-base-url>/v1/otlp/organizations/<your-org-slug>/telemetry/v1/traces
OTEL_EXPORTER_OTLP_HEADERS=Authorization=Basic <base64-encoded-credentials>
OTEL_DEPLOYMENT_ENVIRONMENT=development
