# Copy to .env and fill in your values

# Stripe publishable key — safe to expose in the browser (test mode)
REACT_APP_STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

# Rails backend URL
REACT_APP_BACKEND_URL=http://localhost:3001

# ── Last9 OpenTelemetry (Client Monitoring) ───────────────────────────────────
# Use ORIGIN-RESTRICTED client tokens — NOT backend authorization tokens.
#
# 1. Get your base URL from the Last9 dashboard
# 2. Create a Client Token at https://app.last9.io/control-plane/ingestion-tokens
#    → select "Client Token", set allowed origins (e.g. http://localhost:3000)
# 3. Fill in the values below

REACT_APP_OTEL_SERVICE_NAME=stripe-checkout

REACT_APP_OTEL_TRACES_ENDPOINT=<your-base-url>/v1/otlp/organizations/<your-org-slug>/telemetry/client_monitoring/v1/traces
REACT_APP_OTEL_LOGS_ENDPOINT=<your-base-url>/v1/otlp/organizations/<your-org-slug>/telemetry/client_monitoring/v1/logs

REACT_APP_OTEL_API_TOKEN=your-client-token-here
REACT_APP_OTEL_ORIGIN=http://localhost:3000

REACT_APP_OTEL_ENVIRONMENT=development
